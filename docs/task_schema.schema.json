{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://valuepilot.local/schemas/task_schema.schema.json",
  "title": "ValuePilot Task Schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "task", "authority", "guardrails", "references", "files", "workflow", "execution_plan", "definition_of_done", "validation", "rollback"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },

    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "type", "priority", "owners", "created_at", "tags"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_.-]+$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": ["docs_only"]
        },
        "priority": {
          "type": "string",
          "enum": ["P0", "P1", "P2", "P3"]
        },
        "owners": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["role"],
            "properties": {
              "role": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "created_at": {
          "type": "string",
          "pattern": "^(\\d{4})-(0[1-9]|1[0-2])-(0[1-9]|[12]\\d|3[01])$",
          "description": "Date in YYYY-MM-DD"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },

    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["precedence", "rules"],
      "properties": {
        "precedence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "scope"],
            "properties": {
              "path": { "type": "string", "minLength": 1 },
              "scope": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              }
            }
          },
          "allOf": [
            {
              "contains": {
                "type": "object",
                "required": ["path"],
                "properties": {
                  "path": { "const": "docs/metric_facts_mapping_spec.yml" }
                }
              }
            },
            {
              "contains": {
                "type": "object",
                "required": ["path"],
                "properties": {
                  "path": { "const": "docs/prd/value-pilot-prd-v0.1.md" }
                }
              }
            }
          ]
        },
        "rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "text"],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Z0-9_-]+$"
              },
              "text": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },

    "guardrails": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime_behavior_change", "code_changes", "schema_migration_changes", "allowed_paths", "forbidden_paths", "enforcement"],
      "properties": {
        "runtime_behavior_change": { "type": "string", "enum": ["forbidden", "allowed"] },
        "code_changes": { "type": "string", "enum": ["forbidden", "allowed"] },
        "schema_migration_changes": { "type": "string", "enum": ["forbidden", "allowed"] },
        "allowed_paths": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "forbidden_paths": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "enforcement": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "check"],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Z0-9_-]+$"
              },
              "check": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },

    "references": {
      "type": "object",
      "additionalProperties": false,
      "required": ["prd", "mapping_spec", "decision_records"],
      "properties": {
        "prd": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "mapping_spec": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "decision_records": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },

    "files": {
      "type": "object",
      "additionalProperties": false,
      "required": ["to_change", "notes"],
      "properties": {
        "to_change": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "action"],
            "properties": {
              "path": { "type": "string", "minLength": 1 },
              "action": { "type": "string", "enum": ["edit", "create_optional"] }
            }
          }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requires_human_approval", "approval_gates"],
      "properties": {
        "requires_human_approval": { "type": "boolean" },
        "approval_gates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["gate_id", "required_roles", "description"],
            "properties": {
              "gate_id": { "type": "string", "minLength": 1 },
              "required_roles": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              },
              "description": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },

    "execution_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["steps"],
      "properties": {
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "title", "actions"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "title": { "type": "string", "minLength": 1 },

              "optional": { "type": "boolean" },

              "target_files": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },

              "actions": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              },

              "acceptance_checks": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },

              "non_normative_example": {
                "type": "object",
                "additionalProperties": false,
                "required": ["type", "path"],
                "properties": {
                  "type": { "type": "string", "minLength": 1 },
                  "path": { "type": "string", "minLength": 1 }
                }
              }
            },
            "allOf": [
              {
                "if": {
                  "properties": { "id": { "const": "S4" } },
                  "required": ["id"]
                },
                "then": {
                  "properties": { "optional": { "const": true } }
                }
              }
            ]
          }
        }
      }
    },

    "definition_of_done": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "text"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Z0-9_-]+$"
          },
          "text": { "type": "string", "minLength": 1 }
        }
      }
    },

    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tests"],
      "properties": {
        "tests": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "command", "rationale"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "command": { "type": "string" },
              "rationale": { "type": "string", "minLength": 1 },
              "optional": { "type": "boolean" }
            }
          }
        }
      }
    },

    "rollback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "triggers"],
      "properties": {
        "strategy": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "triggers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "text"],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Z0-9_-]+$"
              },
              "text": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  }
}