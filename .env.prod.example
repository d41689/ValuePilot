# -----------------------------------------------------------------------------
# Database Configuration (Used by docker-compose.prod.yml)
# -----------------------------------------------------------------------------
VALUEPILOT_DB_USER=valuepilot
VALUEPILOT_DB_PASSWORD=your_secure_password_here
VALUEPILOT_PROD_DB=valuepilot_prod

# -----------------------------------------------------------------------------
# Core Application Settings
# -----------------------------------------------------------------------------
# Main database connection string — replace all placeholders with real values.
# Note: ${VAR} shell interpolation is NOT expanded inside .env files.
DATABASE_URL=postgresql://valuepilot:your_secure_password_here@postgres:5432/valuepilot_prod

# Alternative: set the four component variables below instead of DATABASE_URL.
# DATABASE_URL takes priority when both are present.
# POSTGRES_SERVER=postgres
# POSTGRES_USER=valuepilot
# POSTGRES_PASSWORD=your_secure_password_here
# POSTGRES_DB=valuepilot_prod

# Security — SECRET_KEY is required; the application will not start without it.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_a_64_char_random_hex_string
INITIAL_ADMIN_PASSWORD=your_initial_admin_password_here

# EDGAR Identity — SEC requires a User-Agent that identifies your application and contact info.
# Format: "Sample Company Name contact@example.com"
EDGAR_USER_AGENT=ValuePilot contact@valuepilot.com

# -----------------------------------------------------------------------------
# Market Data Providers
# -----------------------------------------------------------------------------
# Options: twelvedata | yfinance | none
MARKET_DATA_PRIMARY=yfinance
MARKET_DATA_SECONDARY=twelvedata
TWELVE_DATA_API_KEY=your_twelve_data_api_key_here

# -----------------------------------------------------------------------------
# Frontend Settings
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=/api/v1

# -----------------------------------------------------------------------------
# Notification Webhooks (Optional)
# -----------------------------------------------------------------------------
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
